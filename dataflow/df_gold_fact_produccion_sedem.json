{
	"name": "df_gold_fact_produccion_sedem",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "tbl_sedem_produccion",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_producto",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_planta",
						"type": "DatasetReference"
					},
					"name": "source3"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_fact_produccion_sedem",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "join2"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          produccion_id as integer,",
				"          planta_id as integer,",
				"          producto_id as integer,",
				"          nro_lote as string,",
				"          fecha_produccion as date,",
				"          fecha_vencimiento as date,",
				"          cantidad_producida as decimal(18,2),",
				"          cantidad_despachada as decimal(18,2),",
				"          costo_produccion_bs as decimal(18,2),",
				"          unidad as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          producto_key as integer,",
				"          producto_id as integer,",
				"          empresa_sigla as string,",
				"          nombre_producto as string,",
				"          categoria as string,",
				"          presentacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source(output(",
				"          planta_key as integer,",
				"          planta_id as integer,",
				"          empresa_sigla as string,",
				"          empresa_nombre as string,",
				"          planta_nombre as string,",
				"          tipo_planta as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          estado_operativo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source3",
				"source1, source2 join(source1@producto_id == source2@producto_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1, source3 join(source1@planta_id == source3@planta_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2 derive(fecha_key = toInteger(toString(fecha_produccion, 'yyyyMMdd'))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          produccion_id,",
				"          nro_lote,",
				"          fecha_produccion,",
				"          fecha_vencimiento,",
				"          cantidad_producida,",
				"          cantidad_despachada,",
				"          costo_produccion_bs,",
				"          unidad,",
				"          producto_key,",
				"          planta_key,",
				"          fecha_key,",
				"          estado = source1@estado",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          produccion_fact_key as integer,",
				"          produccion_id as integer,",
				"          fecha_key as integer,",
				"          fecha_produccion as date,",
				"          fecha_vencimiento as date,",
				"          producto_key as integer,",
				"          planta_key as integer,",
				"          nro_lote as string,",
				"          cantidad_producida as decimal(18,2),",
				"          cantidad_despachada as decimal(18,2),",
				"          costo_produccion_bs as decimal(18,2),",
				"          unidad as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          produccion_id,",
				"          fecha_key,",
				"          fecha_produccion,",
				"          fecha_vencimiento,",
				"          producto_key,",
				"          planta_key,",
				"          nro_lote,",
				"          cantidad_producida,",
				"          cantidad_despachada,",
				"          costo_produccion_bs,",
				"          unidad,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}