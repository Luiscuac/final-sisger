{
	"name": "df_gold_fact_entregas_sup",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "tbl_sup_entregas",
						"type": "DatasetReference"
					},
					"name": "srcSupEntregas"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_persona",
						"type": "DatasetReference"
					},
					"name": "srcDimPersona"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_establecimiento",
						"type": "DatasetReference"
					},
					"name": "srcDimEstablecimiento"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_paquete",
						"type": "DatasetReference"
					},
					"name": "srcDimPaquete"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_fact_entregas_subsidio",
						"type": "DatasetReference"
					},
					"name": "sinkFactSup"
				}
			],
			"transformations": [
				{
					"name": "joinPersona"
				},
				{
					"name": "joinEstablecimiento"
				},
				{
					"name": "joinPaquete"
				},
				{
					"name": "derivedFecha"
				},
				{
					"name": "selectFactSup"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_id as integer,",
				"          boleta_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          paquete_id as integer,",
				"          lote_produccion as string,",
				"          fecha_emision_boleta as date,",
				"          fecha_entrega as date,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcSupEntregas",
				"source(output(",
				"          persona_key as integer,",
				"          ci as string,",
				"          nombre_completo as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as date,",
				"          edad as integer,",
				"          genero as string,",
				"          estado_civil as string,",
				"          numero_hijos as integer,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcDimPersona",
				"source(output(",
				"          establecimiento_key as integer,",
				"          establecimiento_id as integer,",
				"          nombre as string,",
				"          tipo as string,",
				"          municipio as string,",
				"          departamento as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcDimEstablecimiento",
				"source(output(",
				"          paquete_key as integer,",
				"          paquete_id as integer,",
				"          nombre as string,",
				"          peso_estandar_kg as decimal(18,2),",
				"          costo_estimado_bs as decimal(18,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcDimPaquete",
				"srcSupEntregas, srcDimPersona join(ci_beneficiaria == ci,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinPersona",
				"joinPersona, srcDimEstablecimiento join(srcSupEntregas@establecimiento_id == srcDimEstablecimiento@establecimiento_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinEstablecimiento",
				"joinEstablecimiento, srcDimPaquete join(srcSupEntregas@paquete_id == srcDimPaquete@paquete_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinPaquete",
				"joinPaquete derive(fecha_key = toInteger(toString(fecha_entrega, 'yyyyMMdd'))) ~> derivedFecha",
				"derivedFecha select(mapColumn(",
				"          entrega_id,",
				"          fecha_key,",
				"          persona_key,",
				"          establecimiento_key,",
				"          paquete_key,",
				"          lote = lote_produccion,",
				"          estado = estado_civil",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectFactSup",
				"selectFactSup sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_fact_key as integer,",
				"          programa_key as integer,",
				"          entrega_origen_id as integer,",
				"          asignacion_id as integer,",
				"          fecha_key as integer,",
				"          fecha_entrega as date,",
				"          persona_key as integer,",
				"          establecimiento_key as integer,",
				"          paquete_key as integer,",
				"          empleador_key as integer,",
				"          supermercado_key as integer,",
				"          lote as string,",
				"          producto_descripcion as string,",
				"          cantidad_entregas as integer,",
				"          peso_kg as decimal(18,2),",
				"          cantidad_kg as decimal(18,2),",
				"          monto_bs as decimal(18,2),",
				"          costo_estimado_bs as decimal(18,2),",
				"          estado as string,",
				"          canal_entrega as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinkFactSup"
			]
		}
	}
}