		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "adf-ucb-dw-subsidio-8015725"
		},
		"datalake_subsidios_connectionString": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"connectionString\"de \"datalake_subsidios\""
		},
		"dw_subsiduios_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"dw_subsiduios\""
		},
		"dw_subsiduios_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-ucb-sisger-subsidio-8015725.database.windows.net"
		},
		"dw_subsiduios_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "dw_subsidio"
		},
		"dw_subsiduios_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "luis"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
