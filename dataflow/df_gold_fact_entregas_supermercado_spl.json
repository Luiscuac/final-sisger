{
	"name": "df_gold_fact_entregas_supermercado_spl",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "tbl_spl_entregas_supermercado",
						"type": "DatasetReference"
					},
					"name": "srcEntregasSuper"
				},
				{
					"dataset": {
						"referenceName": "tbl_spl_asignaciones",
						"type": "DatasetReference"
					},
					"name": "srcAsignaciones"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_persona",
						"type": "DatasetReference"
					},
					"name": "srcDimPersona"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_empleador",
						"type": "DatasetReference"
					},
					"name": "srcDimEmpleador"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_supermercado",
						"type": "DatasetReference"
					},
					"name": "srcDimSupermercado"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_fact_entregas_supermercado_spl",
						"type": "DatasetReference"
					},
					"name": "sinkFactSuper"
				}
			],
			"transformations": [
				{
					"name": "joinAsignaciones"
				},
				{
					"name": "joinPersona"
				},
				{
					"name": "joinEmpleador"
				},
				{
					"name": "joinSupermercado"
				},
				{
					"name": "derivedFecha"
				},
				{
					"name": "selectFactSuper"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_super_id as integer,",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          supermercado_id as integer,",
				"          fecha_retiro as date,",
				"          tipo_carne as string,",
				"          cantidad_kg as decimal(10,2),",
				"          monto_bs as decimal(10,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcEntregasSuper",
				"source(output(",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          empleador_id as integer,",
				"          mes as integer,",
				"          gestion as integer,",
				"          monto_bs as decimal(10,2),",
				"          monto_productos as decimal(10,2),",
				"          tipo_subsidio as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcAsignaciones",
				"source(output(",
				"          persona_key as integer,",
				"          ci as string,",
				"          nombre_completo as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as date,",
				"          edad as integer,",
				"          genero as string,",
				"          estado_civil as string,",
				"          numero_hijos as integer,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcDimPersona",
				"source(output(",
				"          empleador_key as integer,",
				"          empleador_id as integer,",
				"          razon_social as string,",
				"          tipo as string,",
				"          municipio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcDimEmpleador",
				"source(output(",
				"          supermercado_key as integer,",
				"          supermercado_id as integer,",
				"          cadena as string,",
				"          sucursal as string,",
				"          municipio as string,",
				"          direccion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcDimSupermercado",
				"srcEntregasSuper, srcAsignaciones join(srcEntregasSuper@asignacion_id == srcAsignaciones@asignacion_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinAsignaciones",
				"joinAsignaciones, srcDimPersona join(srcEntregasSuper@ci_beneficiaria == ci,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinPersona",
				"joinPersona, srcDimEmpleador join(srcAsignaciones@empleador_id == srcDimEmpleador@empleador_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinEmpleador",
				"joinEmpleador, srcDimSupermercado join(srcEntregasSuper@supermercado_id == srcDimSupermercado@supermercado_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinSupermercado",
				"joinSupermercado derive(fecha_key = iif(     isNull(fecha_retiro),     (gestion * 10000) + (mes * 100) + 1,     toInteger(toString(fecha_retiro, 'yyyyMMdd')) )) ~> derivedFecha",
				"derivedFecha select(mapColumn(",
				"          entrega_super_id,",
				"          asignacion_id = srcEntregasSuper@asignacion_id,",
				"          fecha_key,",
				"          persona_key,",
				"          empleador_key,",
				"          supermercado_key,",
				"          producto_descripcion = tipo_carne,",
				"          cantidad_kg,",
				"          monto_bs = srcEntregasSuper@monto_bs",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectFactSuper",
				"selectFactSuper sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_super_fact_key as integer,",
				"          entrega_super_id as integer,",
				"          asignacion_id as integer,",
				"          fecha_key as integer,",
				"          persona_key as integer,",
				"          empleador_key as integer,",
				"          supermercado_key as integer,",
				"          producto_descripcion as string,",
				"          cantidad_kg as decimal(18,2),",
				"          monto_bs as decimal(18,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          entrega_super_id,",
				"          asignacion_id,",
				"          fecha_key,",
				"          persona_key,",
				"          empleador_key,",
				"          supermercado_key,",
				"          producto_descripcion,",
				"          cantidad_kg,",
				"          monto_bs",
				"     )) ~> sinkFactSuper"
			]
		}
	}
}