{
	"name": "df_gold_dim_producto",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "tbl_sedem_productos",
						"type": "DatasetReference"
					},
					"name": "srcSilverProductos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_producto",
						"type": "DatasetReference"
					},
					"name": "sinkGoldDimProducto"
				}
			],
			"transformations": [
				{
					"name": "selDimProducto"
				}
			],
			"scriptLines": [
				"source(output(",
				"          producto_id as integer,",
				"          empresa_sigla as string,",
				"          nombre as string,",
				"          categoria as string,",
				"          presentacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcSilverProductos",
				"srcSilverProductos select(mapColumn(",
				"          producto_id,",
				"          empresa_sigla,",
				"          nombre_producto = nombre,",
				"          categoria,",
				"          presentacion,",
				"          estado",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selDimProducto",
				"selDimProducto sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          producto_key as integer,",
				"          producto_id as integer,",
				"          empresa_sigla as string,",
				"          nombre_producto as string,",
				"          categoria as string,",
				"          presentacion as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          producto_id,",
				"          empresa_sigla,",
				"          nombre_producto,",
				"          categoria,",
				"          presentacion,",
				"          estado",
				"     )) ~> sinkGoldDimProducto"
			]
		}
	}
}