{
	"name": "df_gold_dim_persona",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "gold_dim_persona",
						"type": "DatasetReference"
					},
					"name": "srcPersona"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_persona",
						"type": "DatasetReference"
					},
					"name": "sinkGoldDimPersona"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          persona_key as integer,",
				"          ci as string,",
				"          nombre_completo as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as date,",
				"          edad as integer,",
				"          genero as string,",
				"          estado_civil as string,",
				"          numero_hijos as integer,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    ci,\\n    CONCAT(nombres, \\' \\', apellido_paterno, \\' \\', apellido_materno) AS nombre_completo,\\n    nombres,\\n    apellido_paterno,\\n    apellido_materno,\\n    fecha_nacimiento,\\n    DATEDIFF(YEAR, fecha_nacimiento, GETDATE()) AS edad,\\n    genero,\\n    estado_civil,\\n    numero_hijos,\\n    profesion,\\n    nivel_estudios,\\n    municipio_residencia\\nFROM silver.tbl_segip_personas',",
				"     format: 'query') ~> srcPersona",
				"srcPersona sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          persona_key as integer,",
				"          ci as string,",
				"          nombre_completo as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as date,",
				"          edad as integer,",
				"          genero as string,",
				"          estado_civil as string,",
				"          numero_hijos as integer,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ci,",
				"          nombre_completo,",
				"          nombres,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          fecha_nacimiento,",
				"          edad,",
				"          genero,",
				"          estado_civil,",
				"          numero_hijos,",
				"          profesion,",
				"          nivel_estudios,",
				"          municipio_residencia",
				"     )) ~> sinkGoldDimPersona"
			]
		}
	}
}