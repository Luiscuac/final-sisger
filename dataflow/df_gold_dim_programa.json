{
	"name": "df_gold_dim_programa",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "gold_dim_programa",
						"type": "DatasetReference"
					},
					"name": "srcPrograma"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_programa",
						"type": "DatasetReference"
					},
					"name": "sinkGoldDimPrograma"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          codigo_programa as string,",
				"          nombre_programa as string,",
				"          canal_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    CAST(\\'SUP\\' AS VARCHAR(50)) AS codigo_programa,\\n    CAST(\\'Subsidio Universal Prenatal por la Vida\\' AS VARCHAR(200)) AS nombre_programa,\\n    CAST(\\'Establecimiento de salud\\' AS VARCHAR(150)) AS canal_entrega\\n\\nUNION ALL\\n\\nSELECT\\n    CAST(\\'SPL_AGENCIA\\' AS VARCHAR(50)) AS codigo_programa,\\n    CAST(\\'Subsidio Prenatal y de Lactancia\\' AS VARCHAR(200)) AS nombre_programa,\\n    CAST(\\'Agencia Distribuidora\\' AS VARCHAR(150)) AS canal_entrega\\n\\nUNION ALL\\n\\nSELECT\\n    CAST(\\'SPL_SUPERMERCADO\\' AS VARCHAR(50)) AS codigo_programa,\\n    CAST(\\'Subsidio Prenatal y de Lactancia\\' AS VARCHAR(200)) AS nombre_programa,\\n    CAST(\\'Supermercado autorizado\\' AS VARCHAR(150)) AS canal_entrega',",
				"     format: 'query') ~> srcPrograma",
				"srcPrograma sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          programa_key as integer,",
				"          codigo_programa as string,",
				"          nombre_programa as string,",
				"          canal_entrega as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          codigo_programa,",
				"          nombre_programa,",
				"          canal_entrega",
				"     )) ~> sinkGoldDimPrograma"
			]
		}
	}
}