{
	"name": "df_gold_fact_asignaciones_spl",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "tbl_spl_asignaciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_persona",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_empleador",
						"type": "DatasetReference"
					},
					"name": "source3"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_fact_asignaciones_spl",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "join2"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          empleador_id as integer,",
				"          mes as integer,",
				"          gestion as integer,",
				"          monto_bs as decimal(10,2),",
				"          monto_productos as decimal(10,2),",
				"          tipo_subsidio as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          persona_key as integer,",
				"          ci as string,",
				"          nombre_completo as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as date,",
				"          edad as integer,",
				"          genero as string,",
				"          estado_civil as string,",
				"          numero_hijos as integer,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source(output(",
				"          empleador_key as integer,",
				"          empleador_id as integer,",
				"          razon_social as string,",
				"          tipo as string,",
				"          municipio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source3",
				"source1, source2 join(ci_beneficiaria == ci,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1, source3 join(source1@empleador_id == source3@empleador_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2 derive(fecha_key = toInteger((gestion * 10000) + (mes * 100) + 1)) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          asignacion_id,",
				"          mes,",
				"          gestion,",
				"          monto_bs,",
				"          monto_productos,",
				"          tipo_subsidio,",
				"          estado,",
				"          persona_key,",
				"          empleador_key,",
				"          fecha_key",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          asignacion_fact_key as integer,",
				"          asignacion_id as integer,",
				"          fecha_key as integer,",
				"          persona_key as integer,",
				"          empleador_key as integer,",
				"          mes as integer,",
				"          gestion as integer,",
				"          monto_bs as decimal(18,2),",
				"          monto_productos as decimal(18,2),",
				"          tipo_subsidio as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          asignacion_id,",
				"          fecha_key,",
				"          persona_key,",
				"          empleador_key,",
				"          mes,",
				"          gestion,",
				"          monto_bs,",
				"          monto_productos,",
				"          tipo_subsidio,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}