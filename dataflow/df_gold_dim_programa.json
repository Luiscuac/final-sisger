{
	"name": "df_gold_dim_programa",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "gold_dim_programa",
						"type": "DatasetReference"
					},
					"name": "srcPrograma"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_programa",
						"type": "DatasetReference"
					},
					"name": "sinkGoldDimPrograma"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          programa_key as integer,",
				"          codigo_programa as string,",
				"          nombre_programa as string,",
				"          canal_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    CAST(codigo_programa AS VARCHAR(50)) AS codigo_programa,\\n    CAST(nombre_programa AS VARCHAR(200)) AS nombre_programa,\\n    CAST(canal_entrega AS VARCHAR(150)) AS canal_entrega\\nFROM (\\n    VALUES\\n    (\\'SUP\\', \\'Subsidio Universal Prenatal por la Vida\\', \\'Establecimiento de salud\\'),\\n    (\\'SPL_AGENCIA\\', \\'Subsidio Prenatal y de Lactancia\\', \\'Agencia Distribuidora\\'),\\n    (\\'SPL_SUPERMERCADO\\', \\'Subsidio Prenatal y de Lactancia\\', \\'Supermercado autorizado\\')\\n) AS programas(codigo_programa, nombre_programa, canal_entrega)',",
				"     format: 'query') ~> srcPrograma",
				"srcPrograma sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          programa_key as integer,",
				"          codigo_programa as string,",
				"          nombre_programa as string,",
				"          canal_entrega as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          codigo_programa,",
				"          nombre_programa,",
				"          canal_entrega",
				"     )) ~> sinkGoldDimPrograma"
			]
		}
	}
}